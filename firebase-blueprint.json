{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the application",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "name": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "createdAt"]
    },
    "Category": {
      "title": "Category",
      "description": "A transaction category",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "type": { "type": "string", "enum": ["income", "expense"] },
        "color": { "type": "string" },
        "icon": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "name", "type", "createdAt"]
    },
    "FamilyMember": {
      "title": "Family Member",
      "description": "A member of the family",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "role": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "name", "createdAt"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "A financial transaction",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "type": { "type": "string", "enum": ["income", "expense"] },
        "amount": { "type": "number" },
        "categoryId": { "type": "string" },
        "memberId": { "type": "string" },
        "description": { "type": "string" },
        "paymentMethod": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "type", "amount", "categoryId", "date", "createdAt"]
    },
    "Budget": {
      "title": "Budget",
      "description": "A monthly budget for a category",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "categoryId": { "type": "string" },
        "month": { "type": "number" },
        "year": { "type": "number" },
        "limitAmount": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "categoryId", "month", "year", "limitAmount", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles"
    },
    "/categories/{categoryId}": {
      "schema": { "$ref": "#/entities/Category" },
      "description": "Transaction categories"
    },
    "/family_members/{memberId}": {
      "schema": { "$ref": "#/entities/FamilyMember" },
      "description": "Family members"
    },
    "/transactions/{transactionId}": {
      "schema": { "$ref": "#/entities/Transaction" },
      "description": "Financial transactions"
    },
    "/budgets/{budgetId}": {
      "schema": { "$ref": "#/entities/Budget" },
      "description": "Monthly budgets"
    }
  }
}
